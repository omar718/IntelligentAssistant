{
  "name": "project-assistant",
  "displayName": "project-assistant",
  "description": "AI-powered assistant for automatic project onboarding, setup, and configuration",
  "version": "0.0.1",
  "publisher": "Balitzy",
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/Aziz-Ban/project-assistant.git"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "workspaceContains:**"
  ],
  "main": "./dist/extension.js",
"contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "project-assistant-sidebar",
          "title": "Project Assistant",
          "icon": "$(flame)"
        }
      ]
    },
    "views": {
      "project-assistant-sidebar": [
        {
          "type": "webview",
          "id": "project-assistant.assistant",
          "name": "Chat Assistant",
          "icon": "$(comment-discussion)"
        },
        {
          "type": "tree",
          "id": "projectAssistant.projects",
          "name": "My Projects",
          "icon": "$(repo)"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "projectAssistant.projects",
        "contents": "No authenticated projects.\n[Sign In](command:project-assistant.login) • [Sign Out](command:project-assistant.logout)"
      }
    ],
    "commands": [
      {
        "command": "project-assistant.openAssistant",
        "title": "Open Project Assistant"
      },
      {
        "command": "project-assistant.login",
        "title": "Project Assistant: Sign In",
        "icon": "$(account)"
      },
      {
        "command": "project-assistant.logout",
        "title": "Project Assistant: Sign Out",
        "icon": "$(sign-out)"
      },
      {
        "command": "project-assistant.retryConnection",
        "title": "Project Assistant: Retry Connection"
      },
      {
        "command": "project-assistant.inspectAuthState",
        "title": "Project Assistant: Inspect Auth State"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "project-assistant.login",
          "when": "view == projectAssistant.projects && !projectAssistant.authenticated",
          "group": "navigation@9"
        },
        {
          "command": "project-assistant.logout",
          "when": "view == projectAssistant.projects && projectAssistant.authenticated",
          "group": "navigation@10"
        }
      ]
    },
    "keybindings": [
      {
        "command": "project-assistant.openAssistant",
        "key": "ctrl+shift+l",
        "mac": "cmd+shift+l"
      }
    ]
  },
    "scripts": {
    "vscode:prepublish": "npm run package",
    "clean": "rimraf dist out",
    "typecheck": "tsc -p . --noEmit",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run typecheck && npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.15",
    "@types/vscode": "^1.90.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "prettier": "^3.7.4",
    "rimraf": "^6.1.3",
    "ts-loader": "^9.5.4",
    "typescript": "^5.4.2",
    "typescript-eslint": "^8.54.0",
    "webpack": "^5.104.1",
    "webpack-cli": "^6.0.1"
  },
  "dependencies": {
    "axios": "^1.13.6"
  }
  
}
