# Default: normalize all text files to LF in the repo
* text=auto eol=lf

# Force shell scripts to always use LF (critical for Docker/Linux)
*.sh text eol=lf

# Windows-only files can use CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files — no line ending conversion
*.png binary
*.jpg binary
*.ico binary
